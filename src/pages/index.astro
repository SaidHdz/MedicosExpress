---
import Layout from '../layouts/Layout.astro';
import { Icon } from 'astro-icon/components';
import ServiceCard from '../components/ServiceCard.astro';
import BookingForm from '../components/BookingForm';
import { Image } from 'astro:assets';

const heroImage = "https://images.unsplash.com/photo-1622253692010-333f2da6031d?q=80&w=1200&auto=format&fit=crop";
---

<Layout title="Médicos Express: Excelencia Médica sin Esperas en Reynosa">
	<main class="bg-white overflow-hidden">
		<!-- Hero Section -->
		<section class="relative min-h-[90vh] flex items-center bg-slate-50 overflow-hidden">
			<div class="absolute inset-0 bg-gradient-to-br from-blue-50/50 to-white pointer-events-none"></div>
			
			<div class="max-w-7xl mx-auto px-6 py-8 md:py-24 grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center relative z-10">
				
				<!-- Contenido: Texto (Primero en móvil) -->
				<div class="flex flex-col items-center lg:items-start text-center lg:text-left order-1 lg:order-1 mt-8 lg:mt-0">
					<div class="mb-6 inline-flex items-center gap-2 px-4 py-2 bg-blue-50 text-blue-700 rounded-full text-sm font-bold tracking-wide uppercase border border-blue-100 animate-fade-in shadow-sm">
						<span class="relative flex h-3 w-3">
							<span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-blue-400 opacity-75"></span>
							<span class="relative inline-flex rounded-full h-3 w-3 bg-blue-600"></span>
						</span>
						Citas Disponibles Hoy
					</div>

					<h1 class="text-4xl md:text-7xl font-extrabold tracking-tight text-slate-900 mb-6 md:mb-8 leading-[1.05]">
						Salud de <span class="text-blue-600">Primer Nivel</span> en Reynosa Sin Esperas.
					</h1>
					
					<p class="text-lg md:text-2xl text-slate-600 mb-8 md:mb-10 max-w-xl leading-relaxed font-medium">
						Atención profesional, certificada y humana <span class="text-slate-900 font-bold underline decoration-blue-500/30 decoration-4 underline-offset-4">hoy mismo</span>. Tu salud no puede esperar.
					</p>
					
					<div class="flex flex-col sm:flex-row gap-5 w-full sm:w-auto">
						<a 
							href="#agendar" 
							class="group bg-blue-600 hover:bg-blue-700 text-white font-bold py-5 px-10 rounded-2xl transition-all shadow-xl hover:shadow-2xl active:scale-[0.98] flex items-center justify-center gap-3 text-xl"
						>
							<Icon name="lucide:calendar-check" class="w-7 h-7" />
							Agendar Mi Cita
							<Icon name="lucide:arrow-right" class="w-5 h-5 group-hover:translate-x-1 transition-transform" />
						</a>
						<a 
							href="#servicios"
							class="bg-white border-2 border-slate-200 hover:border-blue-200 text-slate-700 font-bold py-5 px-10 rounded-2xl transition-all hover:bg-slate-50 active:scale-[0.98] text-xl shadow-sm text-center"
						>
							Ver Servicios
						</a>
					</div>
				</div>

				<!-- Contenido: Imagen Optimizada (Segundo en móvil) -->
				<div class="relative order-2 lg:order-2 flex justify-center lg:justify-end overflow-visible">
					<div class="relative w-full max-w-[450px] lg:max-w-none">
						<div class="absolute -top-10 -right-10 w-40 h-40 bg-blue-100 rounded-full opacity-50 blur-3xl -z-10"></div>
						
						<Image 
							src={heroImage} 
							alt="Médico profesional atendiendo en clínica de Reynosa" 
							width={1200}
							height={800}
							class="rounded-[2.5rem] shadow-2xl object-cover aspect-[4/5] lg:aspect-auto h-auto max-h-[550px] border-8 border-white animate-float relative z-20"
							loading="eager"
						/>
						
						<!-- Tarjeta flotante de confianza con z-index alto -->
						<div class="absolute -bottom-6 -right-4 md:right-10 bg-white p-6 rounded-3xl shadow-2xl border border-slate-50 z-30 hidden sm:block animate-bounce-slow">
							<div class="flex items-center gap-4">
								<div class="w-12 h-12 bg-blue-600 rounded-full flex items-center justify-center text-white">
									<Icon name="lucide:shield-check" class="w-7 h-7" />
								</div>
								<div>
									<p class="text-xs font-bold text-slate-400 uppercase tracking-widest">Acreditado</p>
									<p class="text-lg font-black text-slate-900">100% Certificado</p>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Services Section -->
		<section id="servicios" class="py-32 px-6 bg-white rounded-[3rem] md:rounded-[5rem] shadow-[0_-20px_50px_-20px_rgba(0,0,0,0.1)] relative z-20 -mt-16">
			<div class="max-w-7xl mx-auto">
				<div class="flex flex-col md:flex-row justify-between items-end gap-8 mb-20 px-4">
					<div class="max-w-2xl">
						<h2 class="text-sm font-black uppercase tracking-[0.3em] text-blue-600 mb-4">
							Nuestros Servicios
						</h2>
						<h3 class="text-3xl md:text-5xl font-extrabold text-slate-900 leading-tight">
							Cuidado Integral para ti y <span class="text-slate-400">tu familia.</span>
						</h3>
					</div>
					<p class="text-lg text-slate-500 font-medium max-w-md">
						Soluciones médicas rápidas con la calidez y profesionalismo que mereces en cada consulta.
					</p>
				</div>

				<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
					<ServiceCard 
						title="Consulta General" 
						description="Atención médica integral para diagnósticos precisos y tratamientos efectivos de padecimientos comunes."
						iconName="lucide:stethoscope"
					/>
					<ServiceCard 
						title="Urgencias Médicas" 
						description="Atención inmediata para situaciones que requieren cuidado urgente sin previa cita."
						iconName="lucide:ambulance"
					/>
					<ServiceCard 
						title="Check-ups" 
						description="Exámenes preventivos completos para monitorear tu salud y detectar riesgos a tiempo."
						iconName="lucide:heart-pulse"
					/>
				</div>
			</div>
		</section>

		<!-- Booking Section -->
		<section id="agendar" class="py-32 px-6 bg-slate-50">
			<div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
				<div>
					<h2 class="text-sm font-black uppercase tracking-[0.3em] text-blue-600 mb-4">
						Agenda tu Cita
					</h2>
					<h3 class="text-4xl md:text-6xl font-extrabold text-slate-900 mb-8 leading-tight">
						Reserva en menos de <span class="text-blue-600 italic">60 segundos.</span>
					</h3>
					<p class="text-xl text-slate-600 mb-10 leading-relaxed font-medium">
						Nuestro sistema automatizado notificará al Dr. instantáneamente. Recibirás una confirmación por WhatsApp en un par de minutos.
					</p>
					
					<div class="space-y-6">
						<div class="flex items-center gap-4">
							<div class="w-12 h-12 bg-white rounded-2xl shadow-sm flex items-center justify-center text-blue-600">
								<Icon name="lucide:check-circle-2" class="w-6 h-6" />
							</div>
							<p class="text-lg font-bold text-slate-700">Sin llamadas telefónicas</p>
						</div>
						<div class="flex items-center gap-4">
							<div class="w-12 h-12 bg-white rounded-2xl shadow-sm flex items-center justify-center text-blue-600">
								<Icon name="lucide:check-circle-2" class="w-6 h-6" />
							</div>
							<p class="text-lg font-bold text-slate-700">Confirmación inmediata vía WhatsApp</p>
						</div>
						<div class="flex items-center gap-4">
							<div class="w-12 h-12 bg-white rounded-2xl shadow-sm flex items-center justify-center text-blue-600">
								<Icon name="lucide:check-circle-2" class="w-6 h-6" />
							</div>
							<p class="text-lg font-bold text-slate-700">Ubicación céntrica en Reynosa</p>
						</div>
					</div>
				</div>

				<div class="relative">
					<div class="absolute -inset-4 bg-blue-100/50 blur-3xl rounded-[3rem] -z-10"></div>
					<BookingForm client:load />
				</div>
			</div>
		</section>
		
		<!-- Trust Badges Section -->
		<section class="py-24 px-6 bg-white border-t border-slate-100">
			<div class="max-w-7xl mx-auto flex flex-col items-center gap-12 text-center">
				<p class="text-sm font-bold uppercase tracking-[0.2em] text-slate-400">
					Acreditación Médica Federal
				</p>
				<div class="flex flex-wrap justify-center gap-12 opacity-60 grayscale hover:grayscale-0 transition-all duration-500">
					<div class="flex items-center gap-3 font-black text-slate-800 text-xl">
						<Icon name="lucide:shield-check" class="w-8 h-8 text-blue-600" />
						Cédula Profesional
					</div>
					<div class="flex items-center gap-3 font-black text-slate-800 text-xl">
						<Icon name="lucide:map-pin" class="w-8 h-8 text-blue-600" />
						Reynosa, Tamps.
					</div>
					<div class="flex items-center gap-3 font-black text-slate-800 text-xl">
						<Icon name="lucide:clock" class="w-8 h-8 text-blue-600" />
						Atención Inmediata
					</div>
				</div>
			</div>
		</section>
	</main>
</Layout>
			<div class="max-w-7xl mx-auto flex flex-col items-center gap-10">
				<p class="text-sm font-bold uppercase tracking-[0.2em] text-slate-400">
					Acreditación Médica Federal
				</p>
				<div class="flex flex-wrap justify-center gap-12 opacity-60 grayscale hover:grayscale-0 transition-all duration-500">
					<div class="flex items-center gap-3 font-bold text-slate-800 text-xl">
						<Icon name="lucide:shield-check" class="w-8 h-8 text-blue-600" />
						Cédula Profesional
					</div>
					<div class="flex items-center gap-3 font-bold text-slate-800 text-xl">
						<Icon name="lucide:map-pin" class="w-8 h-8 text-blue-600" />
						Reynosa, Tamps.
					</div>
					<div class="flex items-center gap-3 font-bold text-slate-800 text-xl">
						<Icon name="lucide:clock" class="w-8 h-8 text-blue-600" />
						Atención Inmediata
					</div>
				</div>
			</div>
		</section>
	</main>
</Layout>

<style>
	@keyframes fade-in {
		from { opacity: 0; transform: translateY(-10px); }
		to { opacity: 1; transform: translateY(0); }
	}
	.animate-fade-in {
		animation: fade-in 0.8s ease-out forwards;
	}
</style>
