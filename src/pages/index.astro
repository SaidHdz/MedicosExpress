---
import Layout from '../layouts/Layout.astro';
import { Icon } from 'astro-icon/components';
import ServiceCard from '../components/ServiceCard.astro';
import BookingForm from '../components/BookingForm';
import { Image } from 'astro:assets';
import { currentClient } from '../config/clients';

const heroImage = currentClient.heroImage;
---

<Layout title={`${currentClient.name}: ${currentClient.tagline}`}>
	<main class="bg-white dark:bg-slate-950 overflow-hidden transition-colors duration-300">
		<!-- Hero Section -->
		<section class="relative min-h-[85vh] flex items-center bg-slate-50 dark:bg-slate-950 overflow-hidden">
			<div 
				class="absolute inset-0 opacity-5 pointer-events-none"
				style={`background-image: radial-gradient(${currentClient.primaryColor} 1px, transparent 1px); background-size: 40px 40px;`}
			></div>
			
			<div class="max-w-7xl mx-auto px-6 py-12 md:py-24 grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center relative z-10">
				
				<!-- Contenido: Texto -->
				<div class="flex flex-col items-center lg:items-start text-center lg:text-left order-1 lg:order-1 mt-8 lg:mt-0">
					<div 
						class="mb-6 inline-flex items-center gap-2 px-4 py-2 rounded-full text-sm font-bold tracking-wide uppercase border animate-fade-in shadow-sm"
						style={`background-color: ${currentClient.primaryColor}1A; color: ${currentClient.primaryColor}; border-color: ${currentClient.primaryColor}33;`}
					>
						<Icon name={currentClient.logoIcon} class="w-5 h-5" />
						{currentClient.tagline}
					</div>

					<h1 
						class="text-4xl md:text-7xl font-extrabold tracking-tight text-slate-900 dark:text-white mb-6 md:mb-8 leading-[1.05]"
						style={`--primary: ${currentClient.primaryColor};`}
						set:html={currentClient.heroTitle}
					></h1>
					
					<p class="text-lg md:text-2xl text-slate-600 dark:text-slate-300 mb-8 md:mb-10 max-w-xl leading-relaxed font-medium">
						Sistema automatizado de citas para <span class="text-slate-900 dark:text-white font-bold italic">{currentClient.name}</span>. Rápido, moderno y sin esperas.
					</p>
					
					<div class="flex flex-col sm:flex-row gap-5 w-full sm:w-auto">
						<a 
							href="#agendar" 
							class="group text-white font-bold py-5 px-10 rounded-2xl transition-all shadow-xl hover:shadow-2xl active:scale-[0.98] flex items-center justify-center gap-3 text-xl"
							style={`background-color: ${currentClient.primaryColor};`}
						>
							<Icon name="lucide:calendar-check" class="w-7 h-7" />
							Agendar Cita Ahora
							<Icon name="lucide:arrow-right" class="w-5 h-5 group-hover:translate-x-1 transition-transform" />
						</a>
						<a 
							href="#servicios"
							class="bg-white dark:bg-slate-900 border-2 border-slate-200 dark:border-slate-800 hover:border-slate-300 dark:hover:border-slate-700 text-slate-700 dark:text-slate-200 font-bold py-5 px-10 rounded-2xl transition-all hover:bg-slate-50 dark:hover:bg-slate-800 active:scale-[0.98] text-xl shadow-sm text-center"
						>
							Nuestros Servicios
						</a>
					</div>
				</div>

				<!-- Contenido: Imagen -->
				<div class="relative order-2 lg:order-2 flex justify-center lg:justify-end overflow-visible">
					<div class="relative w-full max-w-[450px] lg:max-w-none">
						<div 
							class="absolute -top-10 -right-10 w-40 h-40 rounded-full opacity-50 blur-3xl -z-10"
							style={`background-color: ${currentClient.primaryColor}33;`}
						></div>
						
						<Image 
							src={heroImage} 
							alt={`${currentClient.name} Reynosa`}
							width={1200}
							height={800}
							class="rounded-[2.5rem] shadow-2xl object-cover aspect-[4/5] lg:aspect-auto h-auto max-h-[550px] border-8 border-white dark:border-slate-800 animate-float relative z-20"
							loading="eager"
						/>
						
						<div class="absolute -bottom-6 -right-4 md:right-10 bg-white dark:bg-slate-800 p-6 rounded-3xl shadow-2xl border border-slate-50 dark:border-slate-700 z-30 hidden sm:block animate-bounce-slow">
							<div class="flex items-center gap-4">
								<div 
									class="w-12 h-12 rounded-full flex items-center justify-center text-white"
									style={`background-color: ${currentClient.primaryColor};`}
								>
									<Icon name="lucide:shield-check" class="w-7 h-7" />
								</div>
								<div>
									<p class="text-xs font-bold text-slate-400 dark:text-slate-500 uppercase tracking-widest">Acreditado</p>
									<p class="text-lg font-black text-slate-900 dark:text-white">100% Certificado</p>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Sistema Pro -->
		<section class="py-32 px-6 bg-white dark:bg-slate-950 transition-colors duration-300 border-b border-slate-100 dark:border-slate-900">
			<div class="max-w-7xl mx-auto">
				<div class="text-center mb-20">
					<h2 
						class="text-sm font-black uppercase tracking-[0.3em] mb-4"
						style={`color: ${currentClient.primaryColor};`}
					>
						Tecnología de Vanguardia
					</h2>
					<h3 class="text-4xl md:text-6xl font-extrabold text-slate-900 dark:text-white leading-tight">
						El Sistema <span class="italic" style={`color: ${currentClient.primaryColor};`}>{currentClient.shortName} Pro</span>
					</h3>
				</div>

				<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
					<div class="group relative p-10 bg-slate-50 dark:bg-slate-900/50 rounded-[2.5rem] border border-slate-100 dark:border-slate-800 transition-all hover:shadow-2xl hover:-translate-y-1 overflow-hidden">
						<div class="absolute -bottom-6 -right-2 text-9xl font-black text-slate-200/50 dark:text-slate-800/30 group-hover:opacity-5 transition-colors italic pointer-events-none select-none">01</div>
						<div 
							class="w-12 h-12 text-white rounded-xl flex items-center justify-center mb-8 shadow-lg relative z-10"
							style={`background-color: ${currentClient.primaryColor};`}
						>
							<Icon name="lucide:calendar-days" class="w-6 h-6" />
						</div>
						<h4 class="text-2xl font-bold text-slate-900 dark:text-white mb-4 relative z-10">Agendamiento 24/7</h4>
						<p class="text-slate-600 dark:text-slate-400 font-medium leading-relaxed relative z-10">Elige tu horario ideal desde cualquier dispositivo, a cualquier hora del día.</p>
					</div>
					<div class="group relative p-10 bg-slate-50 dark:bg-slate-900/50 rounded-[2.5rem] border border-slate-100 dark:border-slate-800 transition-all hover:shadow-2xl hover:-translate-y-1 overflow-hidden">
						<div class="absolute -bottom-6 -right-2 text-9xl font-black text-slate-200/50 dark:text-slate-800/30 group-hover:opacity-5 transition-colors italic pointer-events-none select-none">02</div>
						<div 
							class="w-12 h-12 text-white rounded-xl flex items-center justify-center mb-8 shadow-lg relative z-10"
							style={`background-color: ${currentClient.primaryColor};`}
						>
							<Icon name="lucide:check-circle" class="w-6 h-6" />
						</div>
						<h4 class="text-2xl font-bold text-slate-900 dark:text-white mb-4 relative z-10">Sin Empalmes</h4>
						<p class="text-slate-600 dark:text-slate-400 font-medium leading-relaxed relative z-10">Nuestro sistema inteligente garantiza que tu tiempo sea respetado sin retrasos.</p>
					</div>
					<div class="group relative p-10 bg-slate-50 dark:bg-slate-900/50 rounded-[2.5rem] border border-slate-100 dark:border-slate-800 transition-all hover:shadow-2xl hover:-translate-y-1 overflow-hidden">
						<div class="absolute -bottom-6 -right-2 text-9xl font-black text-slate-200/50 dark:text-slate-800/30 group-hover:opacity-5 transition-colors italic pointer-events-none select-none">03</div>
						<div 
							class="w-12 h-12 text-white rounded-xl flex items-center justify-center mb-8 shadow-lg relative z-10"
							style={`background-color: ${currentClient.primaryColor};`}
						>
							<Icon name="lucide:bell" class="w-6 h-6" />
						</div>
						<h4 class="text-2xl font-bold text-slate-900 dark:text-white mb-4 relative z-10">Recordatorios</h4>
						<p class="text-slate-600 dark:text-slate-400 font-medium leading-relaxed relative z-10">Recibe una notificación automática por WhatsApp para que nunca olvides tu cita.</p>
					</div>
				</div>
			</div>
		</section>

		<!-- Services Section -->
		<section id="servicios" class="py-32 px-6 bg-white dark:bg-slate-900 transition-colors duration-300">
			<div class="max-w-7xl mx-auto">
				<div class="flex flex-col md:flex-row justify-between items-end gap-8 mb-20 px-4">
					<div class="max-w-2xl">
						<h2 
							class="text-sm font-black uppercase tracking-[0.3em] mb-4"
							style={`color: ${currentClient.primaryColor};`}
						>
							Nuestros Servicios
						</h2>
						<h3 class="text-3xl md:text-5xl font-extrabold text-slate-900 dark:text-white leading-tight">Especialidades <span class="text-slate-400 dark:text-slate-600">Certificadas.</span></h3>
					</div>
					<p class="text-lg text-slate-500 dark:text-slate-400 font-medium max-w-md">Soluciones modernas con la calidez y profesionalismo que tú y tu familia merecen.</p>
				</div>

				<div class="grid grid-cols-1 md:grid-cols-3 gap-8 items-stretch">
					{currentClient.services.map(service => (
						<ServiceCard title={service.title} description={service.description} iconName={service.icon} />
					))}
				</div>
			</div>
		</section>

		<!-- Especialidades Section -->
		<section class="py-32 px-6 bg-white dark:bg-slate-900 overflow-hidden">
			<div class="max-w-7xl mx-auto">
				<div class="text-center mb-20">
					<h2 
						class="text-sm font-black uppercase tracking-[0.3em] mb-4"
						style={`color: ${currentClient.primaryColor};`}
					>
						Autoridad Médica
					</h2>
					<h3 class="text-4xl md:text-6xl font-extrabold text-slate-900 dark:text-white leading-tight">Expertos <span class="italic" style={`color: ${currentClient.primaryColor};`}>Certificados</span></h3>
					<p class="mt-6 text-xl text-slate-500 dark:text-slate-400 max-w-2xl mx-auto font-medium">Contamos con un equipo altamente calificado dedicado a tu bienestar integral.</p>
				</div>

				<div class="grid grid-cols-1 md:grid-cols-2 lg:flex lg:flex-wrap lg:justify-center gap-8">
					{currentClient.specialties.map(spec => (
						<div class="group p-8 bg-slate-50 dark:bg-slate-800/50 rounded-[2.5rem] border border-slate-100 dark:border-slate-800 transition-all hover:shadow-2xl hover:-translate-y-2 w-full lg:w-[calc(25%-2rem)] flex flex-col">
							<div 
								class="w-14 h-14 bg-white dark:bg-slate-800 rounded-2xl flex items-center justify-center mb-6 shadow-sm group-hover:text-white transition-all duration-300"
								style={`color: ${currentClient.primaryColor}; --hover-bg: ${currentClient.primaryColor};`}
							>
								<Icon name={spec.icon} class="w-7 h-7" />
							</div>
							<h4 class="text-2xl font-bold text-slate-900 dark:text-white mb-3">{spec.name}</h4>
							<p class="text-slate-600 dark:text-slate-400 font-medium leading-relaxed flex-grow">{spec.desc}</p>
							<div class="mt-6 pt-6 border-t border-slate-200/50 dark:border-slate-700/50">
								<a 
									href="#agendar" 
									class="text-sm font-bold flex items-center gap-2 group/link"
									style={`color: ${currentClient.primaryColor};`}
								>
									Agendar cita
									<Icon name="lucide:chevron-right" class="w-4 h-4 group-hover/link:translate-x-1 transition-transform" />
								</a>
							</div>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- Sucursales Section -->
		<section id="sucursales" class="py-32 px-6 bg-slate-50 dark:bg-slate-950">
			<div class="max-w-7xl mx-auto">
				<div class="text-center mb-20">
					<h2 
						class="text-sm font-black uppercase tracking-[0.3em] mb-4"
						style={`color: ${currentClient.primaryColor};`}
					>
						Nuestra Ubicación
					</h2>
					<h3 class="text-4xl md:text-6xl font-extrabold text-slate-900 dark:text-white leading-tight italic">{currentClient.name} Reynosa</h3>
				</div>
				<div class="flex justify-center">
					<div class="bg-white dark:bg-slate-900 p-10 rounded-[2.5rem] border border-slate-100 dark:border-slate-800 shadow-xl group flex flex-col items-center text-center max-w-lg w-full">
						<div 
							class="w-16 h-16 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform"
							style={`background-color: ${currentClient.primaryColor}1A; color: ${currentClient.primaryColor};`}
						>
							<Icon name="lucide:map-pin" class="w-8 h-8" />
						</div>
						<h4 class="text-2xl font-bold text-slate-900 dark:text-white mb-4">Sucursal Principal</h4>
						<p class="text-slate-500 dark:text-slate-400 text-lg mb-8 leading-relaxed">{currentClient.address}</p>
						<div class="mb-10">
							<div class="inline-flex items-center gap-2 text-sm font-bold text-green-600 dark:text-green-400 bg-green-50 dark:bg-green-900/20 px-4 py-2 rounded-full italic">{currentClient.schedule}</div>
						</div>
						<a 
							href={currentClient.mapsLink} 
							target="_blank" 
							class="flex items-center justify-center gap-3 w-full py-5 text-white rounded-2xl font-bold text-lg transition-all shadow-lg"
							style={`background-color: ${currentClient.primaryColor}; shadow-color: ${currentClient.primaryColor}33;`}
						>
							Ver en Google Maps <Icon name="lucide:external-link" class="w-5 h-5" />
						</a>
					</div>
				</div>
			</div>
		</section>

		<!-- Booking Section -->
		<section id="agendar" class="py-32 px-6 bg-white dark:bg-slate-900">
			<div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
				<div>
					<h2 
						class="text-sm font-black uppercase tracking-[0.3em] mb-4"
						style={`color: ${currentClient.primaryColor};`}
					>
						Agenda tu Cita
					</h2>
					<h3 class="text-4xl md:text-6xl font-extrabold text-slate-900 dark:text-white mb-8 leading-tight">Tu bienestar a un <span class="italic" style={`color: ${currentClient.primaryColor};`}>click de distancia.</span></h3>
					<p class="text-xl text-slate-600 dark:text-slate-300 mb-10 leading-relaxed font-medium">Nuestro sistema automatizado confirmará tu horario de atención al instante.</p>
					<div class="space-y-6">
						{[ "Confirmación vía WhatsApp", "Especialistas Certificados", "Tecnología Digital"].map(text => (
							<div class="flex items-center gap-4">
								<div 
									class="w-12 h-12 rounded-2xl flex items-center justify-center"
									style={`background-color: ${currentClient.primaryColor}1A; color: ${currentClient.primaryColor};`}
								>
									<Icon name="lucide:check-circle-2" class="w-6 h-6" />
								</div>
								<p class="text-lg font-bold text-slate-700 dark:text-slate-300">{text}</p>
							</div>
						))}
					</div>
				</div>
				<div class="relative">
					<div 
						class="absolute -inset-4 blur-3xl rounded-[3rem] -z-10"
						style={`background-color: ${currentClient.primaryColor}0D;`}
					></div>
					<BookingForm client:load />
				</div>
			</div>
		</section>
	</main>
</Layout>

<style>
	@keyframes fade-in { from { opacity: 0; transform: translateY(-10px); } to { opacity: 1; transform: translateY(0); } }
	.animate-fade-in { animation: fade-in 0.8s ease-out forwards; }
	
	/* Hover dinámico para especialidades */
	.group:hover [style*="--hover-bg"] {
		background-color: var(--hover-bg) !important;
	}
</style>
