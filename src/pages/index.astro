---
import Layout from '../layouts/Layout.astro';
import { Icon } from 'astro-icon/components';
import ServiceCard from '../components/ServiceCard.astro';
import BookingForm from '../components/BookingForm';
import { Image } from 'astro:assets';

const heroImage = "https://images.unsplash.com/photo-1606811841689-23dfddce3e95?q=80&w=1200&auto=format&fit=crop";
---

<Layout title="Smylife Dental: Agenda tu próxima sonrisa en Reynosa">
	<main class="bg-white dark:bg-slate-950 overflow-hidden transition-colors duration-300">
		<!-- Hero Section -->
		<section class="relative min-h-[85vh] flex items-center bg-slate-50 dark:bg-slate-950 overflow-hidden">
			<div class="absolute inset-0 bg-gradient-to-br from-[#00AEEF]/5 to-white dark:from-slate-900/50 dark:to-slate-950 pointer-events-none"></div>
			
			<div class="max-w-7xl mx-auto px-6 py-12 md:py-24 grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center relative z-10">
				
				<!-- Contenido: Texto -->
				<div class="flex flex-col items-center lg:items-start text-center lg:text-left order-1 lg:order-1 mt-8 lg:mt-0">
					<div class="mb-6 inline-flex items-center gap-2 px-4 py-2 bg-[#00AEEF]/10 dark:bg-[#00AEEF]/20 text-[#00AEEF] rounded-full text-sm font-bold tracking-wide uppercase border border-[#00AEEF]/10 dark:border-[#00AEEF]/30 animate-fade-in shadow-sm">
						<Icon name="lucide:smile" class="w-5 h-5" />
						Tu sonrisa, nuestra prioridad
					</div>

					<h1 class="text-4xl md:text-7xl font-extrabold tracking-tight text-slate-900 dark:text-white mb-6 md:mb-8 leading-[1.05]">
						Agenda tu próxima <span class="text-[#00AEEF]">sonrisa</span> en menos de 60 segundos.
					</h1>
					
					<p class="text-lg md:text-2xl text-slate-600 dark:text-slate-300 mb-8 md:mb-10 max-w-xl leading-relaxed font-medium">
						Sistema automatizado de citas para <span class="text-slate-900 dark:text-white font-bold italic">Smylife Dental</span>. Rápido, moderno y sin esperas.
					</p>
					
					<div class="flex flex-col sm:flex-row gap-5 w-full sm:w-auto">
						<a 
							href="#agendar" 
							class="group bg-[#00AEEF] hover:bg-[#009ED9] text-white font-bold py-5 px-10 rounded-2xl transition-all shadow-xl hover:shadow-2xl active:scale-[0.98] flex items-center justify-center gap-3 text-xl"
						>
							<Icon name="lucide:calendar-check" class="w-7 h-7" />
							Agendar Cita Ahora
							<Icon name="lucide:arrow-right" class="w-5 h-5 group-hover:translate-x-1 transition-transform" />
						</a>
						<a 
							href="#servicios"
							class="bg-white dark:bg-slate-900 border-2 border-slate-200 dark:border-slate-800 hover:border-[#00AEEF] text-slate-700 dark:text-slate-200 font-bold py-5 px-10 rounded-2xl transition-all hover:bg-slate-50 dark:hover:bg-slate-800 active:scale-[0.98] text-xl shadow-sm text-center"
						>
							Nuestros Servicios
						</a>
					</div>
				</div>

				<!-- Contenido: Imagen -->
				<div class="relative order-2 lg:order-2 flex justify-center lg:justify-end overflow-visible">
					<div class="relative w-full max-w-[450px] lg:max-w-none">
						<div class="absolute -top-10 -right-10 w-40 h-40 bg-[#00AEEF]/10 dark:bg-[#00AEEF]/20 rounded-full opacity-50 blur-3xl -z-10"></div>
						
						<Image 
							src={heroImage} 
							alt="Odontólogo profesional en clínica Smylife Dental Reynosa" 
							width={1200}
							height={800}
							class="rounded-[2.5rem] shadow-2xl object-cover aspect-[4/5] lg:aspect-auto h-auto max-h-[550px] border-8 border-white dark:border-slate-800 animate-float relative z-20"
							loading="eager"
						/>
						
						<div class="absolute -bottom-6 -right-4 md:right-10 bg-white dark:bg-slate-800 p-6 rounded-3xl shadow-2xl border border-slate-50 dark:border-slate-700 z-30 hidden sm:block animate-bounce-slow">
							<div class="flex items-center gap-4">
								<div class="w-12 h-12 bg-blue-600 rounded-full flex items-center justify-center text-white">
									<Icon name="lucide:shield-check" class="w-7 h-7" />
								</div>
								<div>
									<p class="text-xs font-bold text-slate-400 dark:text-slate-500 uppercase tracking-widest">Acreditado</p>
									<p class="text-lg font-black text-slate-900 dark:text-white">100% Certificado</p>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Sistema Smylife -->
		<section class="py-32 px-6 bg-white dark:bg-slate-950 transition-colors duration-300 border-b border-slate-100 dark:border-slate-900">
			<div class="max-w-7xl mx-auto">
				<div class="text-center mb-20">
					<h2 class="text-sm font-black uppercase tracking-[0.3em] text-[#00AEEF] mb-4">
						Tecnología Odontológica
					</h2>
					<h3 class="text-4xl md:text-6xl font-extrabold text-slate-900 dark:text-white leading-tight">
						El Sistema <span class="text-[#00AEEF] italic">Smylife Pro</span>
					</h3>
				</div>

				<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
					<div class="group relative p-10 bg-slate-50 dark:bg-slate-900/50 rounded-[2.5rem] border border-slate-100 dark:border-slate-800 transition-all hover:shadow-2xl hover:shadow-[#00AEEF]/10 hover:-translate-y-1 overflow-hidden">
						<div class="absolute -bottom-6 -right-2 text-9xl font-black text-slate-200/50 dark:text-slate-800/30 group-hover:text-[#00AEEF]/5 transition-colors italic pointer-events-none select-none">01</div>
						<div class="w-12 h-12 bg-[#00AEEF] text-white rounded-xl flex items-center justify-center mb-8 shadow-lg relative z-10">
							<Icon name="lucide:calendar-days" class="w-6 h-6" />
						</div>
						<h4 class="text-2xl font-bold text-slate-900 dark:text-white mb-4 relative z-10">Agendamiento 24/7</h4>
						<p class="text-slate-600 dark:text-slate-400 font-medium leading-relaxed relative z-10">Elige tu horario ideal desde cualquier dispositivo, a cualquier hora del día.</p>
					</div>
					<div class="group relative p-10 bg-slate-50 dark:bg-slate-900/50 rounded-[2.5rem] border border-slate-100 dark:border-slate-800 transition-all hover:shadow-2xl hover:shadow-[#00AEEF]/10 hover:-translate-y-1 overflow-hidden">
						<div class="absolute -bottom-6 -right-2 text-9xl font-black text-slate-200/50 dark:text-slate-800/30 group-hover:text-[#00AEEF]/5 transition-colors italic pointer-events-none select-none">02</div>
						<div class="w-12 h-12 bg-[#00AEEF] text-white rounded-xl flex items-center justify-center mb-8 shadow-lg relative z-10">
							<Icon name="lucide:check-circle" class="w-6 h-6" />
						</div>
						<h4 class="text-2xl font-bold text-slate-900 dark:text-white mb-4 relative z-10">Sin Empalmes</h4>
						<p class="text-slate-600 dark:text-slate-400 font-medium leading-relaxed relative z-10">Nuestro sistema inteligente garantiza que tu tiempo sea respetado sin retrasos.</p>
					</div>
					<div class="group relative p-10 bg-slate-50 dark:bg-slate-900/50 rounded-[2.5rem] border border-slate-100 dark:border-slate-800 transition-all hover:shadow-2xl hover:shadow-[#00AEEF]/10 hover:-translate-y-1 overflow-hidden">
						<div class="absolute -bottom-6 -right-2 text-9xl font-black text-slate-200/50 dark:text-slate-800/30 group-hover:text-[#00AEEF]/5 transition-colors italic pointer-events-none select-none">03</div>
						<div class="w-12 h-12 bg-[#00AEEF] text-white rounded-xl flex items-center justify-center mb-8 shadow-lg relative z-10">
							<Icon name="lucide:bell" class="w-6 h-6" />
						</div>
						<h4 class="text-2xl font-bold text-slate-900 dark:text-white mb-4 relative z-10">Recordatorios</h4>
						<p class="text-slate-600 dark:text-slate-400 font-medium leading-relaxed relative z-10">Recibe una notificación automática por WhatsApp para que nunca olvides tu cita.</p>
					</div>
				</div>
			</div>
		</section>

		<!-- Services Section -->
		<section id="servicios" class="py-32 px-6 bg-white dark:bg-slate-900 transition-colors duration-300">
			<div class="max-w-7xl mx-auto">
				<div class="flex flex-col md:flex-row justify-between items-end gap-8 mb-20 px-4">
					<div class="max-w-2xl">
						<h2 class="text-sm font-black uppercase tracking-[0.3em] text-[#00AEEF] mb-4">Nuestros Servicios</h2>
						<h3 class="text-3xl md:text-5xl font-extrabold text-slate-900 dark:text-white leading-tight">Especialidades <span class="text-slate-400 dark:text-slate-600">Odontológicas.</span></h3>
					</div>
					<p class="text-lg text-slate-500 dark:text-slate-400 font-medium max-w-md">Soluciones dentales modernas con la calidez y profesionalismo que tu sonrisa merece.</p>
				</div>

				<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
					<ServiceCard title="Limpieza Dental" description="Profilaxis profesional para mantener tus dientes y encías saludables." iconName="lucide:sparkles" />
					<ServiceCard title="Valoración Inicial" description="Diagnóstico completo con tecnología digital para tu plan de tratamiento." iconName="lucide:clipboard-list" />
					<ServiceCard title="Ortodoncia" description="Diseño de sonrisa con Brackets de última generación para todas las edades." iconName="lucide:layers" />
					<ServiceCard title="Blanqueamiento" description="Recupera el brillo natural de tu sonrisa con resultados inmediatos." iconName="lucide:zap" />
				</div>
			</div>
		</section>

		<!-- Especialidades Section -->
		<section class="py-32 px-6 bg-white dark:bg-slate-900 overflow-hidden">
			<div class="max-w-7xl mx-auto">
				<div class="text-center mb-20">
					<h2 class="text-sm font-black uppercase tracking-[0.3em] text-[#00AEEF] mb-4">Autoridad Dental</h2>
					<h3 class="text-4xl md:text-6xl font-extrabold text-slate-900 dark:text-white leading-tight">Especialistas <span class="text-[#00AEEF] italic">Certificados</span></h3>
					<p class="mt-6 text-xl text-slate-500 dark:text-slate-400 max-w-2xl mx-auto font-medium">Expertos altamente calificados dedicados a brindar una atención humana y de excelencia en odontología.</p>
				</div>

				<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
					{[
						{ name: "Endodoncia", desc: "Tratamientos de conductos avanzados para salvar tus piezas dentales.", icon: "lucide:activity" },
						{ name: "Periodoncia", desc: "Cuidado especializado de las encías y tejidos de soporte.", icon: "lucide:shield-plus" },
						{ name: "Odontopediatría", desc: "Atención dental experta y divertida para los más pequeños.", icon: "lucide:baby" },
						{ name: "Rehabilitación", desc: "Prótesis e implantes para recuperar la funcionalidad y estética.", icon: "lucide:wrench" }
					].map(spec => (
						<div class="group p-8 bg-slate-50 dark:bg-slate-800/50 rounded-[2.5rem] border border-slate-100 dark:border-slate-800 transition-all hover:shadow-2xl hover:shadow-[#00AEEF]/5 hover:-translate-y-2">
							<div class="w-14 h-14 bg-white dark:bg-slate-800 text-[#00AEEF] rounded-2xl flex items-center justify-center mb-6 shadow-sm group-hover:bg-[#00AEEF] group-hover:text-white transition-all duration-300">
								<Icon name={spec.icon} class="w-7 h-7" />
							</div>
							<h4 class="text-2xl font-bold text-slate-900 dark:text-white mb-3">{spec.name}</h4>
							<p class="text-slate-600 dark:text-slate-400 font-medium leading-relaxed">{spec.desc}</p>
							<div class="mt-6 pt-6 border-t border-slate-200/50 dark:border-slate-700/50">
								<a href="#agendar" class="text-sm font-bold text-[#00AEEF] hover:text-[#009ED9] flex items-center gap-2 group/link">
									Agendar cita
									<Icon name="lucide:chevron-right" class="w-4 h-4 group-hover/link:translate-x-1 transition-transform" />
								</a>
							</div>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- Sucursales Section -->
		<section id="sucursales" class="py-32 px-6 bg-slate-50 dark:bg-slate-950">
			<div class="max-w-7xl mx-auto">
				<div class="text-center mb-20">
					<h2 class="text-sm font-black uppercase tracking-[0.3em] text-[#00AEEF] mb-4">Nuestra Ubicación</h2>
					<h3 class="text-4xl md:text-6xl font-extrabold text-slate-900 dark:text-white leading-tight italic">Smylife Dental Reynosa</h3>
				</div>
				<div class="flex justify-center">
					<div class="bg-white dark:bg-slate-900 p-10 rounded-[2.5rem] border border-slate-100 dark:border-slate-800 shadow-xl group flex flex-col items-center text-center max-w-lg w-full">
						<div class="w-16 h-16 bg-[#00AEEF]/10 text-[#00AEEF] rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform"><Icon name="lucide:map-pin" class="w-8 h-8" /></div>
						<h4 class="text-2xl font-bold text-slate-900 dark:text-white mb-4">Sucursal Principal</h4>
						<p class="text-slate-500 dark:text-slate-400 text-lg mb-8 leading-relaxed">Parque Alcala #632, FRACC. Balcones de Alcala, Reynosa, Mexico</p>
						<div class="mb-10">
							<div class="inline-flex items-center gap-2 text-sm font-bold text-green-600 dark:text-green-400 bg-green-50 dark:bg-green-900/20 px-4 py-2 rounded-full italic">Atención de Lunes a Sábado</div>
						</div>
						<a href="https://maps.app.goo.gl/VrSoEZ23bAQPcQUz7" target="_blank" class="flex items-center justify-center gap-3 w-full py-5 bg-[#00AEEF] text-white rounded-2xl font-bold text-lg hover:bg-[#009ED9] transition-all shadow-lg shadow-[#00AEEF]/20">Ver en Google Maps <Icon name="lucide:external-link" class="w-5 h-5" /></a>
					</div>
				</div>
			</div>
		</section>

		<!-- Booking Section -->
		<section id="agendar" class="py-32 px-6 bg-white dark:bg-slate-900">
			<div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
				<div>
					<h2 class="text-sm font-black uppercase tracking-[0.3em] text-[#00AEEF] mb-4">Agenda tu Cita</h2>
					<h3 class="text-4xl md:text-6xl font-extrabold text-slate-900 dark:text-white mb-8 leading-tight">Tu sonrisa perfecta a un <span class="text-[#00AEEF] italic">click de distancia.</span></h3>
					<p class="text-xl text-slate-600 dark:text-slate-300 mb-10 leading-relaxed font-medium">Nuestro sistema automatizado confirmará tu horario de valoración al instante.</p>
					<div class="space-y-6">
						{[ "Confirmación vía WhatsApp", "Especialistas en Estética", "Tecnología Digital"].map(text => (
							<div class="flex items-center gap-4"><div class="w-12 h-12 bg-[#00AEEF]/10 rounded-2xl flex items-center justify-center text-[#00AEEF]"><Icon name="lucide:check-circle-2" class="w-6 h-6" /></div><p class="text-lg font-bold text-slate-700 dark:text-slate-300">{text}</p></div>
						))}
					</div>
				</div>
				<div class="relative"><div class="absolute -inset-4 bg-[#00AEEF]/5 blur-3xl rounded-[3rem] -z-10"></div><BookingForm client:load /></div>
			</div>
		</section>
	</main>
</Layout>

<style>
	@keyframes fade-in { from { opacity: 0; transform: translateY(-10px); } to { opacity: 1; transform: translateY(0); } }
	.animate-fade-in { animation: fade-in 0.8s ease-out forwards; }
</style>
