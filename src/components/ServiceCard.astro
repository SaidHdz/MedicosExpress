---
import { Icon } from 'astro-icon/components';

interface Props {
	title: string;
	description: string;
	iconName: string;
}

const { title, description, iconName } = Astro.props;
---

<div class="group p-8 bg-white border border-slate-100 rounded-3xl transition-all duration-300 hover:shadow-2xl hover:shadow-blue-100 hover:-translate-y-2 flex flex-col items-start gap-4 cursor-default">
	<div class="w-14 h-14 bg-blue-50 text-blue-600 rounded-2xl flex items-center justify-center group-hover:bg-blue-600 group-hover:text-white transition-colors duration-300">
		<Icon name={iconName} class="w-8 h-8" />
	</div>
	
	<h3 class="text-xl font-bold text-slate-900 mt-2">
		{title}
	</h3>
	
	<p class="text-slate-600 leading-relaxed font-medium">
		{description}
	</p>
</div>
