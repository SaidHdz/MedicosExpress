---
import { Icon } from 'astro-icon/components';
import { currentClient } from '../config/clients';

interface Props {
	title: string;
	description: string;
	iconName: string;
}

const { title, description, iconName } = Astro.props;
---

<div 
	class="group p-8 bg-white dark:bg-slate-900 border border-slate-100 dark:border-slate-800 rounded-3xl transition-all duration-300 hover:shadow-2xl hover:-translate-y-2 flex flex-col items-start gap-4 cursor-default"
	style={`--primary: ${currentClient.primaryColor};`}
>
	<div 
		class="w-14 h-14 rounded-2xl flex items-center justify-center group-hover:text-white transition-all duration-300"
		style={`background-color: ${currentClient.primaryColor}1A; color: ${currentClient.primaryColor}; --hover-bg: ${currentClient.primaryColor};`}
	>
		<Icon name={iconName} class="w-8 h-8" />
	</div>
	
	<h3 class="text-xl font-bold text-slate-900 dark:text-white mt-2">
		{title}
	</h3>
	
	<p class="text-slate-600 dark:text-slate-400 leading-relaxed font-medium">
		{description}
	</p>
</div>

<style>
	.group:hover div[style*="--hover-bg"] {
		background-color: var(--hover-bg) !important;
	}
</style>
